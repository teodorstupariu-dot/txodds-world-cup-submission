# Copy to .env only for local use. Never commit the populated .env file.

# TxLINE access
TXLINE_NETWORK=mainnet
TXLINE_ORIGIN=https://txline.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_TIMEOUT=30
TXLINE_RETRIES=2
TXLINE_BACKOFF_SECONDS=0.5
TXLINE_MAX_RESPONSE_BYTES=10000000

# ProofGuard live service
# AUTO uses LIVE only when credentials, fixture, and explicit model probabilities exist.
PROOFGUARD_MODE=AUTO
PROOFGUARD_FIXTURE_ID=
PROOFGUARD_MODEL_PROBABILITIES_JSON={"HOME":0.58,"DRAW":0.25,"AWAY":0.17}
# Alternative to inline JSON; keep the referenced file private and ignored.
PROOFGUARD_MODEL_PROBABILITIES_FILE=
PROOFGUARD_POLL_SECONDS=60
PROOFGUARD_WITH_SCORES=true
PROOFGUARD_REPLAY_FALLBACK=true
PROOFGUARD_AUTO_START=true
PROOFGUARD_MAX_RECEIPTS=100
PORT=8080
